{% comment %}
  Editorial Split — asymmetrical two-column storytelling module
  (cinematic image + heading/paragraph).

  Layout rules:
  - Mobile: always stacked, image on top. The image markup is always
    first in the DOM, so this holds regardless of `image_position`.
  - Desktop (>=750px): CSS Grid, image column ~60% / text column ~40%.
    `image_position` only flips the *visual* side via `order`; the DOM
    (and reading/accessibility order) never changes.
{% endcomment %}

{% liquid
  assign heading = section.settings.heading
  assign paragraph = section.settings.paragraph
  assign image = section.settings.texture_image
  assign position = section.settings.image_position
  assign sizes = '(min-width: 750px) 60vw, 100vw'
  assign image_alt = image.alt | escape
%}

<section
  class="editorial-split editorial-split--{{ position }}"
  {% if heading != blank %}
    aria-labelledby="EditorialSplit-{{ section.id }}"
  {% endif %}
>
  <div class="editorial-split__media">
    {%- if image -%}
      {{
        image
        | image_url: width: 1600
        | image_tag:
          loading: 'lazy',
          sizes: sizes,
          widths: '375, 550, 750, 1100, 1500, 1780, 2000',
          alt: image_alt,
          class: 'editorial-split__image'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-split__image editorial-split__placeholder' }}
    {%- endif -%}
  </div>

  <div class="editorial-split__content">
    <div class="editorial-split__content-inner">
      {%- if heading != blank -%}
        <h2 id="EditorialSplit-{{ section.id }}" class="editorial-split__heading">
          {{ heading | escape }}
        </h2>
      {%- endif -%}

      {%- if paragraph != blank -%}
        <div class="editorial-split__paragraph rte">
          {{ paragraph }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .editorial-split {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 6vw, 4rem);
    padding-block: clamp(3rem, 8vw, 6rem);
    background-color: var(--color-ivory);
    color: var(--color-navy);
  }

  /* Media */
  .editorial-split__media {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .editorial-split__image,
  .editorial-split__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .editorial-split__placeholder {
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  /* Content */
  .editorial-split__content {
    display: flex;
    align-items: center;
  }

  .editorial-split__content-inner {
    max-width: 42rem;
    padding-block: 0.5rem;
  }

  .editorial-split__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: 0.01em;
    margin: 0 0 1.5rem;
    padding-bottom: 1.25rem;
    position: relative;
  }

  .editorial-split__heading::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 3.5rem;
    height: 2px;
    background-color: var(--color-gold);
  }

  .editorial-split__paragraph {
    font-family: var(--font-primary--family);
    font-style: var(--font-primary--style);
    font-weight: var(--font-primary--weight);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .editorial-split__paragraph p {
    margin: 0 0 1em;
  }

  .editorial-split__paragraph p:last-child {
    margin-bottom: 0;
  }

  .editorial-split__paragraph a {
    color: var(--color-gold);
    text-decoration-line: underline;
    text-decoration-color: var(--color-gold-soft);
    text-underline-offset: 0.2em;
    transition: color 0.2s ease;
  }

  .editorial-split__paragraph a:hover {
    color: var(--color-navy);
  }

  .editorial-split a:focus-visible,
  .editorial-split__heading:focus-visible {
    outline: 2px solid var(--color-gold-soft);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-split__paragraph a {
      transition: none;
    }
  }

  /* Desktop: 60/40 asymmetrical grid. Image stays first in the DOM
     (mobile-first stacking requirement); `order` flips the *visual*
     position only, so the accessibility/reading order never changes. */
  @media screen and (min-width: 750px) {
    .editorial-split {
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: clamp(2rem, 4vw, 5rem);
      align-items: stretch;
    }

    .editorial-split--text_first {
      grid-template-columns: 2fr 3fr;
    }

    .editorial-split--text_first .editorial-split__media {
      order: 2;
    }

    .editorial-split--text_first .editorial-split__content {
      order: 1;
    }

    .editorial-split__media {
      aspect-ratio: 16 / 10;
      height: 100%;
    }

    .editorial-split__content-inner {
      padding: 2rem 3rem;
    }
  }

  @media screen and (min-width: 990px) {
    .editorial-split__content-inner {
      padding: 2rem 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.editorial_split",
  "settings": [
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "info": "t:info.image_position_mobile",
      "options": [
        {
          "value": "image_first",
          "label": "t:options.image_position.image_first"
        },
        {
          "value": "text_first",
          "label": "t:options.image_position.text_first"
        }
      ],
      "default": "image_first"
    },
    {
      "type": "image_picker",
      "id": "texture_image",
      "label": "t:labels.texture_image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "An Editorial Story"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "t:labels.detail_paragraph",
      "default": "<p>Add a paragraph describing the craftsmanship, heritage, or story behind this piece.</p>"
    }
  ],
  "presets": [
    {
      "name": "t:general.editorial_split"
    }
  ]
}
{% endschema %}
