{
  "sections": {
    "hero": {
      "type": "product-hero",
      "settings": {
        "tagline": "Hand-finished 600–900 thread count cotton sateen. King, and only King.",
        "color_scheme": "scheme-4"
      }
    },
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "none"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "trust_badges": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "leaf",
            "heading_1": "100% cotton sateen",
            "icon_2": "check_mark",
            "heading_2": "Hand-finished, Batch of Forty",
            "icon_3": "lock",
            "heading_3": "Secure checkout"
          }
        },
        "description": {
          "type": "description"
        },
        "tab_weave": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "The Weave",
            "icon": "leaf",
            "content": "<p>600–900 thread count, 100% cotton sateen. Woven for a soft, subtle sheen and a drape that holds up wash after wash, not just on the first night.</p><p>Crafted in the Nile Delta, refined in the UK — every set is hand-finished, not machine-stamped.</p>"
          }
        },
        "tab_care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care",
            "icon": "washing",
            "content": "<p>Machine wash cold on a gentle cycle. Tumble dry low, or line dry to preserve the sateen finish longest. Do not bleach. Iron on a low setting if a crisper finish is preferred.</p>"
          }
        },
        "tab_shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & The Archive",
            "icon": "truck",
            "content": "<p>Part of Batch 01 — forty numbered sets. Each set ships insured and individually numbered. Please allow standard processing time before dispatch.</p>"
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "variant_picker",
        "buy_buttons",
        "trust_badges",
        "description",
        "tab_weave",
        "tab_care",
        "tab_shipping"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "thumbnail",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "show",
        "hide_variants": false,
        "enable_video_looping": false,
        "padding_top": 48,
        "padding_bottom": 24
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "The Other Sets in the Archive",
        "heading_size": "h2",
        "products_to_show": 5,
        "columns_desktop": 5,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
  },
  "order": [
    "hero",
    "main",
    "related-products"
  ]
}
