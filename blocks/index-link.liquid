{% doc %}
  Renders a single entry in the Atelier Homepage Portal's vertical
  product index (a numbered link to one product).

  Numbering ("01", "02"...) is handled entirely by a CSS counter on
  the parent <ol> (see `sections/atelier-homepage-portal.liquid`), so
  this block never needs to know its own position in the list.

  @param {product} [product] - The product this index entry links to

  @example
  {% content_for 'block', type: 'index-link', id: 'index-link' %}
{% enddoc %}

<li class="index-link" {{ block.shopify_attributes }}>
  {%- if block.settings.product -%}
    <a class="index-link__link" href="{{ block.settings.product.url }}">
      {{ block.settings.product.title | escape }}
    </a>
  {%- else -%}
    <span class="index-link__link index-link__link--placeholder">
      {{ 'products.select_product' | t }}
    </span>
  {%- endif -%}
</li>

{% stylesheet %}
  .index-link {
    counter-increment: index-link;
    border-bottom: 1px solid rgba(2, 0, 45, 0.08);
  }

  .index-link:first-child {
    border-top: 1px solid rgba(2, 0, 45, 0.08);
  }

  .index-link__link {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.1rem, 3vh, 1.75rem);
    font-family: var(--font-primary--family);
    font-style: var(--font-primary--style);
    font-weight: var(--font-primary--weight);
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-navy);
    transition:
      letter-spacing 0.4s cubic-bezier(0.19, 1, 0.22, 1),
      color 0.3s ease,
      opacity 0.3s ease;
  }

  .index-link__link::before {
    content: counter(index-link, decimal-leading-zero);
    flex-shrink: 0;
    font-size: 0.7em;
    letter-spacing: 0.05em;
    color: var(--color-gold);
  }

  .index-link__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-gold);
    transition: width 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .index-link__link:hover,
  .index-link__link:focus-visible {
    letter-spacing: 0.14em;
    color: var(--color-gold);
  }

  .index-link__link:hover::after,
  .index-link__link:focus-visible::after {
    width: 100%;
  }

  .index-link__link:focus-visible {
    outline: 1px solid var(--color-gold);
    outline-offset: 6px;
  }

  .index-link__link--placeholder {
    color: rgba(2, 0, 45, 0.35);
    cursor: default;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .index-link__link {
      transition: none;
    }
  }

  @media screen and (min-width: 750px) {
    .index-link__link {
      padding-block: clamp(1rem, 2.6vh, 1.5rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.index_link",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:labels.product"
    }
  ]
}
{% endschema %}
